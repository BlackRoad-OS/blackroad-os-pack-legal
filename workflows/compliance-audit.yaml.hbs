# name: compliance-audit
# required_secrets:
#   - AUDIT_API_TOKEN
# reviewers:
#   - compliance-lead

on:
  schedule:
    - cron: '0 6 * * 1'
jobs:
  audit:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: pnpm/action-setup@v4
        with:
          version: 8
      - name: Install dependencies
        run: pnpm install --frozen-lockfile
      - name: Lint policies
        run: pnpm ts-node src/cli.ts lint-policies
      - name: Export policy bundle
        env:
          AUDIT_API_TOKEN: ${{ secrets.AUDIT_API_TOKEN }}
        run: |
          tar -czf policies.tar.gz policies
          echo "Uploading policies for audit"
          # TODO(legal-pack-next): post bundle to audit endpoint
